# Environment Variables Configuration
# Copy this to .env and fill in your values

# ============================================================================
# REQUIRED
# ============================================================================

# Your Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ============================================================================
# OPTIONAL - Game Configuration (with defaults)
# ============================================================================

# Database location (SQLite)
DATABASE_PATH=./alice.db

# Total game duration in minutes
GAME_DURATION_MINUTES=95

# Number of trigger cards each player receives
TRIGGERS_PER_PLAYER=15

# Wait this many seconds before sending first trigger (let players read secret)
FIRST_TRIGGER_AFTER_SECONDS=90

# Suspense duration: how long to show "typing" before each trigger
TYPING_BEFORE_TRIGGER_SECONDS=4

# Game phases - minutes from start when phase changes
EARLY_PHASE_END=20
MID_PHASE_END=45

# Minimum players required to start a game
MIN_PLAYERS=2

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Rate limiting: max commands per user per minute
RATE_LIMIT_COMMANDS=10

# Auto-end games inactive for this many minutes
GAME_INACTIVITY_TIMEOUT_MINUTES=120

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================
# 
# LOCAL DEVELOPMENT:
#   - Create .env file in project root
#   - Run: source .env (Linux/Mac) or set vars manually (Windows)
#   - Run: python main.py
#
# DOCKER:
#   - Pass as -e flags: docker run -e TELEGRAM_BOT_TOKEN=xxx ...
#   - Or in docker-compose.yml environment section
#
# SYSTEMD:
#   - Set in /etc/systemd/system/alice-bot.service [Service] Environment= lines
#
# HEROKU/RAILWAY/etc:
#   - Set in platform's environment variable UI
#
